{
  "version": 2,
  "buildCommand": "pnpm prisma generate && pnpm db:push --accept-data-loss && pnpm build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
