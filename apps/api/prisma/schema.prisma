// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DevToArticle {
  id        Int      @id @default(autoincrement())
  url       String
  title     String
  author    String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GithubRepository {
  id          Int      @id @default(autoincrement())
  url         String
  name        String
  owner       String
  description String
  language    String
  stars       String
  forks       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HackerNewsStory {
  id          Int     @id
  title       String
  url         String? // Some stories may not have a URL
  by          String
  score       Int
  time        Int // Unix timestamp
  descendants Int // Number of comments
  type        String // Usually "story"
}
