generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DevToArticle {
  id        Int      @id @default(autoincrement())
  url       String
  title     String
  author    String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GithubRepository {
  id          Int      @id @default(autoincrement())
  url         String
  name        String
  owner       String
  description String
  language    String
  stars       String
  forks       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
